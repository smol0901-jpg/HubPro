{
  "name": "hubpro",
  "version": "1.3.0",
  "description": "Профессиональный центр управления Telegram ботами",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "web": "node web-server.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "author": "NEURAL_ARCHITECT_PREMIUM++",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "sql.js": "^1.10.3",
    "electron-updater": "^6.1.7",
    "express": "^4.18.2"
  },
  "build": {
    "appId": "com.hubpro.app",
    "productName": "HubPro",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "renderer/**/*", "build/**/*", "node_modules/sql.js/dist/**/*"],
    "extraResources": [{ "from": "node_modules/sql.js/dist/sql-wasm.wasm", "to": "sql-wasm.wasm" }],
    "win": { "target": [{"target": "nsis", "arch": ["x64"]}], "icon": "build/icon.ico" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true },
    "publish": { "provider": "github", "owner": "smol0901-jpg", "repo": "HubPro" }
  }
}