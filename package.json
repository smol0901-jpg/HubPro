{
  "name": "hubpro",
  "version": "1.1.0",
  "description": "Профессиональный центр управления Telegram ботами с автообновлением",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "author": "NEURAL_ARCHITECT_PREMIUM++",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "electron-updater": "^6.1.7",
    "electron-log": "^5.0.1"
  },
  "build": {
    "appId": "com.hubpro.app",
    "productName": "HubPro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "smol0901-jpg",
      "repo": "HubPro"
    }
  }
}