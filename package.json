{
  "name": "hubpro",
  "v": "2.3.2",
  "description": "\u0423\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u0431\u043e\u0442\u0430\u043c\u0438 Telegram",
  "main": "main.js",
  "scripts": {
    "start": "node main.js",
    "build": "electron-builder --win -x64",
    "dev": "electron ."
  },
  "keyword": [
    "telegram",
    "bot",
    "automation"
  ],
  "author": "ASV_prod",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "body-parser": "^1.20.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "telegraf": "^4.15.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.hubpro.app",
    "productName": "HubPro",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "renderer/**.*",
      "package.json"
    ],
    "win": {
      "target": "[nsis]",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectors": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HubPro"
    }
  }
}